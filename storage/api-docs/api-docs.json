                                "properties": {
                                    "id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "user_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "degree": {
                                        "type": "string",
                                        "example": "BS Computer Science"
                                    },
                                    "degree_title": {
                                        "type": "string",
                                        "example": "Bachelor of Science"
                                    },
                                    "majors": {
                                        "type": "string",
                                        "example": "Computer Science"
                                    },
                                    "institute_name": {
                                        "type": "string",
                                        "example": "Virtual University"
                                    },
                                    "board_name": {
                                        "type": "string",
                                        "example": "HEC"
                                    },
                                    "start_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2021-01-01"
                                    },
                                    "end_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2024-01-01"
                                    },
                                    "obtained_marks": {
                                        "type": "integer",
                                        "example": 800
                                    },
                                    "total_marks": {
                                        "type": "integer",
                                        "example": 1000
                                    },
                                    "obtained_percentage": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 80.5
                                    },
                                    "grade": {
                                        "type": "string",
                                        "example": "A"
                                    },
                                    "foreign_qualified": {
                                        "type": "string",
                                        "enum": [
                                            "Yes",
                                            "No"
                                        ],
                                        "example": "No"
                                    },
                                    "education_document": {
                                        "type": "string",
                                        "format": "binary"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Education updated successfully"
                    },
                    "422": {
                        "description": "Validation error"
                    },
                    "404": {
                        "description": "Education not found"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/education/delete": {
            "delete": {
                "tags": [
                    "Education"
                ],
                "summary": "Delete Education",
                "operationId": "deleteEducation",
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
