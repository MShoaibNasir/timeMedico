{
    "openapi": "3.0.0",
    "info": {
        "title": "PICG API Documentation",
        "description": "This documentation covers all API endpoints for the PICG project.",
        "version": "1.0.0"
    },
    "servers": [
        {
            "url": "/api"
        }
    ],
    "paths": {
        "/api/education/store": {
            "post": {
                "tags": [
                    "Education"
                ],
                "summary": "Store Education",
                "operationId": "storeEducation",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "user_id",
                                    "degree",
                                    "degree_title",
                                    "majors",
                                    "institute_name",
                                    "board_name",
                                    "start_date",
                                    "end_date",
                                    "obtained_marks",
                                    "total_marks",
                                    "obtained_percentage",
                                    "grade",
                                    "foreign_qualified",
                                    "education_document"
                                ],
                                "properties": {
                                    "user_id": {
                                        "type": "integer",
                                        "example": 1
                                    },
                                    "degree": {
                                        "type": "string",
                                        "example": "BS"
                                    },
                                    "degree_title": {
                                        "type": "string",
                                        "example": "BS Computer Science"
                                    },
                                    "majors": {
                                        "type": "string",
                                        "example": "Computer Science"
                                    },
                                    "institute_name": {
                                        "type": "string",
                                        "example": "Virtual University"
                                    },
                                    "board_name": {
                                        "type": "string",
                                        "example": "BISE Lahore"
                                    },
                                    "start_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2021-01-01"
                                    },
                                    "end_date": {
                                        "type": "string",
                                        "format": "date",
                                        "example": "2024-01-01"
                                    },
                                    "obtained_marks": {
                                        "type": "integer",
                                        "example": 850
                                    },
                                    "total_marks": {
                                        "type": "integer",
                                        "example": 1100
                                    },
                                    "obtained_percentage": {
                                        "type": "number",
                                        "format": "float",
                                        "example": 77.27
                                    },
                                    "grade": {
                                        "type": "string",
                                        "example": "A"
                                    },
                                    "foreign_qualified": {
                                        "type": "string",
                                        "enum": [
                                            "Yes",
                                            "No"
                                        ],
                                        "example": "No"
                                    },
                                    "education_document": {
                                        "type": "string",
                                        "example": "documents/degree.pdf"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Education created successfully"
                    },
                    "422": {
                        "description": "Validation error"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/education/show": {
            "get": {
                "tags": [
                    "Education"
                ],
                "summary": "Get education record by ID",
                "operationId": "showEducation",
                "parameters": [
                    {
                        "name": "id",
                        "in": "query",
                        "description": "ID of the education record",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "example": 1
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Success",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found"
                    }
                },
                "security": [
                    {
                        "sanctum": []
                    }
                ]
            }
        },
        "/api/education/update": {
            "put": {
                "tags": [
                    "Education"
                ],
